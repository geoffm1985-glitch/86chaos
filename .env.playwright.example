# Copy this to .env.playwright, then fill in your testing/preview credentials.
# Do NOT use production if you turn mutation mode on.

CHAOS_BASE_URL=http://localhost:3000
CHAOS_EXPECTED_VERSION=15.1.10

OWNER_EMAIL=
OWNER_PASSWORD=

# Optional but strongly recommended for permission checks:
MANAGER_EMAIL=
MANAGER_PASSWORD=
STAFF_EMAIL=
STAFF_PASSWORD=
SYSTEM_ADMIN_EMAIL=
SYSTEM_ADMIN_PASSWORD=

# Optional denial accounts:
WRONG_WORKSPACE_EMAIL=
WRONG_WORKSPACE_PASSWORD=
DISABLED_EMAIL=
DISABLED_PASSWORD=

# Keep off unless running against a disposable testing workspace.
CHAOS_ALLOW_MUTATION=0

# Route performance budget, default 30000ms.
CHAOS_ROUTE_MAX_MS=30000
