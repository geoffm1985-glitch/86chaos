rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function uploadPurposeIs(expected) {
      return request.resource != null && request.resource.metadata is map && request.resource.metadata.purpose == expected;
    }

    function userPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function userDoc() {
      return firestore.get(userPath()).data;
    }

    function restaurantPath(restaurantId) {
      return /databases/(default)/documents/restaurants/$(restaurantId);
    }

    function restaurantDoc(restaurantId) {
      return firestore.get(restaurantPath(restaurantId)).data;
    }

    function isSuperAdmin() {
      return signedIn() && (
        request.auth.token.superAdmin == true ||
        userDoc().get('isSuperAdmin', false) == true ||
        userDoc().get('systemAccess', {}).get('superAdmin', false) == true
      );
    }

    function membershipMapHas(restaurantId) {
      return signedIn() &&
        userDoc().memberships is map &&
        userDoc().memberships[restaurantId] is map &&
        userDoc().memberships[restaurantId].isActive == true;
    }

    function workspaceIdsHas(restaurantId) {
      return signedIn() && userDoc().workspaceIds is list && userDoc().workspaceIds.hasAny([restaurantId]);
    }

    function isTenantMatch(restaurantId) {
      return signedIn() && (
        userDoc().restaurantId == restaurantId ||
        workspaceIdsHas(restaurantId) ||
        membershipMapHas(restaurantId)
      );
    }

    function isRestaurantOwner(restaurantId) {
      return signedIn() && (
        isSuperAdmin() ||
        (
          restaurantDoc(restaurantId).get('ownerEmail', '') == request.auth.token.email ||
          restaurantDoc(restaurantId).get('ownerEmailLower', '') == request.auth.token.email ||
          restaurantDoc(restaurantId).get('ownerUserEmail', '') == request.auth.token.email ||
          restaurantDoc(restaurantId).get('ownerUserId', '') == request.auth.uid ||
          restaurantDoc(restaurantId).get('ownerUid', '') == request.auth.uid
        ) ||
        (
          membershipMapHas(restaurantId) && (
            userDoc().memberships[restaurantId].get('isOwner', false) == true ||
            userDoc().memberships[restaurantId].get('accountOwner', false) == true ||
            userDoc().memberships[restaurantId].get('workspaceOwner', false) == true ||
            userDoc().memberships[restaurantId].get('accountRole', '') == 'owner'
          )
        ) ||
        (
          !membershipMapHas(restaurantId) && userDoc().restaurantId == restaurantId && (
            userDoc().get('isOwner', false) == true ||
            userDoc().get('accountOwner', false) == true ||
            userDoc().get('owner', false) == true ||
            userDoc().get('workspaceOwner', false) == true ||
            userDoc().get('accountRole', '') == 'owner'
          )
        )
      );
    }

    function isAdminFor(restaurantId) {
      return isTenantMatch(restaurantId) && (
        (membershipMapHas(restaurantId) && userDoc().memberships[restaurantId].get('isAdmin', false) == true) ||
        (!membershipMapHas(restaurantId) && userDoc().restaurantId == restaurantId && userDoc().get('isAdmin', false) == true)
      );
    }

    function hasPermFor(restaurantId, permission) {
      return isTenantMatch(restaurantId) && (
        (
          membershipMapHas(restaurantId) &&
          userDoc().memberships[restaurantId].permissions is map &&
          userDoc().memberships[restaurantId].permissions[permission] == true
        ) ||
        (
          !membershipMapHas(restaurantId) &&
          userDoc().restaurantId == restaurantId &&
          userDoc().permissions is map &&
          userDoc().permissions[permission] == true
        )
      );
    }

    function canManageBrandAssets(restaurantId) {
      return isSuperAdmin() ||
        isRestaurantOwner(restaurantId) ||
        isAdminFor(restaurantId) ||
        hasPermFor(restaurantId, 'branding') ||
        hasPermFor(restaurantId, 'settings');
    }

    function canUseMenuIntelligence(restaurantId) {
      return isSuperAdmin() ||
        isRestaurantOwner(restaurantId) ||
        isAdminFor(restaurantId) ||
        hasPermFor(restaurantId, 'menuIntelligence') ||
        hasPermFor(restaurantId, 'inventory') ||
        hasPermFor(restaurantId, 'inventoryEdit');
    }

    function canUseInvoiceScans(restaurantId) {
      return isSuperAdmin() ||
        isRestaurantOwner(restaurantId) ||
        isAdminFor(restaurantId) ||
        hasPermFor(restaurantId, 'inventory') ||
        hasPermFor(restaurantId, 'inventoryEdit') ||
        hasPermFor(restaurantId, 'invoiceScan') ||
        hasPermFor(restaurantId, 'scans') ||
        hasPermFor(restaurantId, 'financialEdit');
    }

    function canManageProfilePhoto(restaurantId, uid) {
      return isSuperAdmin() ||
        (signedIn() && request.auth.uid == uid) ||
        isRestaurantOwner(restaurantId) ||
        isAdminFor(restaurantId) ||
        hasPermFor(restaurantId, 'team');
    }

    function isAllowedImage() {
      return request.resource != null &&
        request.resource.size < 8 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    function isAllowedDocument() {
      return request.resource != null &&
        request.resource.size < 15 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
      );
    }

    function isHrOwnerFor(restaurantId) {
      return signedIn() && (
        (
          membershipMapHas(restaurantId) && (
            userDoc().memberships[restaurantId].get('isOwner', false) == true ||
            userDoc().memberships[restaurantId].get('accountOwner', false) == true ||
            userDoc().memberships[restaurantId].get('workspaceOwner', false) == true ||
            userDoc().memberships[restaurantId].get('accountRole', '') == 'owner'
          )
        ) ||
        (
          !membershipMapHas(restaurantId) && userDoc().restaurantId == restaurantId && (
            userDoc().get('isOwner', false) == true ||
            userDoc().get('accountOwner', false) == true ||
            userDoc().get('owner', false) == true ||
            userDoc().get('workspaceOwner', false) == true ||
            userDoc().get('accountRole', '') == 'owner'
          )
        )
      );
    }

    function isHrAdminFor(restaurantId) {
      return isTenantMatch(restaurantId) && (
        (membershipMapHas(restaurantId) && userDoc().memberships[restaurantId].get('isAdmin', false) == true) ||
        (!membershipMapHas(restaurantId) && userDoc().restaurantId == restaurantId && userDoc().get('isAdmin', false) == true)
      );
    }

    function hasHrPermissionFor(restaurantId) {
      return isTenantMatch(restaurantId) && (
        (
          membershipMapHas(restaurantId) &&
          userDoc().memberships[restaurantId].permissions is map &&
          userDoc().memberships[restaurantId].permissions.hr == true
        ) ||
        (
          !membershipMapHas(restaurantId) &&
          userDoc().restaurantId == restaurantId &&
          userDoc().permissions is map &&
          userDoc().permissions.hr == true
        )
      );
    }

    function canManageHr(restaurantId) {
      return isSuperAdmin() || isHrOwnerFor(restaurantId) || isHrAdminFor(restaurantId) || hasHrPermissionFor(restaurantId);
    }

    function trainingManualPath(manualId) {
      return /databases/(default)/documents/trainingManuals/$(manualId);
    }

    function publishedTrainingManualFor(restaurantId, manualId) {
      let manual = firestore.get(trainingManualPath(manualId)).data;
      return manual.restaurantId == restaurantId && manual.status == 'Published';
    }

    function isAllowedTrainingManual(restaurantId, manualId) {
      return request.resource != null &&
        uploadPurposeIs('hr-training-manual') &&
        request.resource.metadata.restaurantId == restaurantId &&
        request.resource.metadata.manualId == manualId &&
        request.resource.size > 0 &&
        request.resource.size <= 15 * 1024 * 1024 &&
        request.resource.contentType in [
          'application/pdf',
          'application/msword',
          'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
          'text/plain'
        ];
    }

    function isAllowedInvoiceScan() {
      return request.resource != null &&
        uploadPurposeIs('invoice-scan') &&
        request.resource.size <= 20 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
        );
    }

    function isAllowedMenuUpload() {
      return request.resource != null &&
        uploadPurposeIs('menu-scan') &&
        request.resource.size <= 20 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
        );
    }

    // Restaurant-scoped profile photos. Users may manage only their own photo unless they manage staff.
    match /{restaurantId}/profilePhotos/{uid}/{fileName} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if canManageProfilePhoto(restaurantId, uid) && isAllowedImage();
    }

    match /{restaurantId}/profilePhotos/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if false;
    }

    // Restaurant-scoped branding/logo assets.
    // 86 Chaos branding is locked in the app. This path is only for customer restaurant logos.
    match /{restaurantId}/brandAssets/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if canManageBrandAssets(restaurantId) && isAllowedImage();
    }

    // Legacy Cheers branding path from older Settings builds. Current builds use
    // restaurant-scoped brandAssets, but this keeps older deployed clients from
    // hitting storage/unauthorized while the update rolls out.
    match /cheers-restaurant-assets/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch('cheers_chilton_01');
      allow write: if canManageBrandAssets('cheers_chilton_01') && isAllowedImage();
    }

    // Restaurant-scoped message attachments.
    match /{restaurantId}/messageAttachments/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if (isSuperAdmin() || isTenantMatch(restaurantId)) && isAllowedDocument();
    }

    // Restaurant-scoped maintenance photos.
    match /{restaurantId}/maintenancePhotos/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if (isSuperAdmin() || isTenantMatch(restaurantId)) && isAllowedImage();
    }

    // Restaurant-scoped invoice scans. Invoice files are limited to inventory/scan/financial-authorized users.
    match /{restaurantId}/invoices/{allPaths=**} {
      allow read: if canUseInvoiceScans(restaurantId);
      allow write: if canUseInvoiceScans(restaurantId) && isAllowedInvoiceScan();
    }

    // Restaurant-scoped menu uploads for Menu Intelligence review.
    match /{restaurantId}/menuUploads/{allPaths=**} {
      allow read: if canUseMenuIntelligence(restaurantId);
      allow write: if canUseMenuIntelligence(restaurantId) && isAllowedMenuUpload();
    }

    // Versioned HR training manuals. Employees may fetch only files whose
    // matching Firestore record is currently Published. HR managers may upload,
    // inspect, and delete any version for their own workspace.
    match /{restaurantId}/hrTrainingManuals/{manualId}/{allPaths=**} {
      allow read: if canManageHr(restaurantId) ||
        (isTenantMatch(restaurantId) && publishedTrainingManualFor(restaurantId, manualId));
      allow create: if canManageHr(restaurantId) && isAllowedTrainingManual(restaurantId, manualId);
      allow update: if false;
      allow delete: if canManageHr(restaurantId);
    }

    // Backups are Super Admin only. No regular signed-in user can read or write backups.
    match /backups/{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }

    // Locked production fallback. Anything not explicitly allowed above is denied.
    // Do not replace this with signed-in read/write access.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
