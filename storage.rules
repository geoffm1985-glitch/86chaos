rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return signedIn() && (
        request.auth.token.superAdmin == true ||
        request.auth.token.email == 'geoffm1985@gmail.com' ||
        (signedIn() && userDoc().isSuperAdmin == true)
      );
    }

    function isTenantMatch(restaurantId) {
      return signedIn() && userDoc().restaurantId == restaurantId;
    }

    function canManageBrandAssets(restaurantId) {
      return isSuperAdmin() ||
        (isTenantMatch(restaurantId) && (
          userDoc().isOwner == true ||
          userDoc().accountOwner == true ||
          userDoc().owner == true ||
          userDoc().workspaceOwner == true ||
          userDoc().accountRole == 'owner' ||
          userDoc().isAdmin == true ||
          (userDoc().permissions is map && (userDoc().permissions.branding == true || userDoc().permissions.settings == true))
        ));
    }

    function isAllowedImage() {
      return request.resource != null &&
        request.resource.size < 8 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    function isAllowedDocument() {
      return request.resource != null &&
        request.resource.size < 15 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
        );
    }

    function isAllowedInvoiceScan() {
      return request.resource != null &&
        request.resource.size < 50 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
        );
    }

    // Restaurant-scoped profile photos.
    match /{restaurantId}/profilePhotos/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if (isSuperAdmin() || isTenantMatch(restaurantId)) && isAllowedImage();
    }

    // Restaurant-scoped branding/logo assets.
    match /{restaurantId}/brandAssets/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if canManageBrandAssets(restaurantId) && isAllowedImage();
    }



    // Legacy Cheers branding path from older Settings builds. New builds do not
    // expose restaurant-logo display, but this keeps an older deployed client from
    // hitting storage/unauthorized while the update rolls out.
    match /cheers-restaurant-assets/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch('cheers_chilton_01');
      allow write: if canManageBrandAssets('cheers_chilton_01') && isAllowedImage();
    }

    // Restaurant-scoped message attachments.
    match /{restaurantId}/messageAttachments/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if (isSuperAdmin() || isTenantMatch(restaurantId)) && isAllowedDocument();
    }

    // Restaurant-scoped maintenance photos.
    match /{restaurantId}/maintenancePhotos/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if (isSuperAdmin() || isTenantMatch(restaurantId)) && isAllowedImage();
    }

    // Restaurant-scoped invoice scans.
    match /{restaurantId}/invoices/{allPaths=**} {
      allow read: if isSuperAdmin() || isTenantMatch(restaurantId);
      allow write: if (isSuperAdmin() || isTenantMatch(restaurantId)) && isAllowedInvoiceScan();
    }

    // Backups are Super Admin only. No regular signed-in user can read or write backups.
    match /backups/{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }

    // Locked production fallback. Anything not explicitly allowed above is denied.
    // Do not replace this with signed-in read/write access.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
