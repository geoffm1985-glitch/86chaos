# 86 Chaos DEEP DEEP Playwright tests
# Copy to .env.playwright.deep and fill in real test accounts.

# Use local dev server by default. To test preview/prod, set the full URL.
CHAOS_BASE_URL=http://localhost:3000
CHAOS_EXPECTED_VERSION=15.1.13

# Required for most tests
OWNER_EMAIL=
OWNER_PASSWORD=

# Strongly recommended for permission tests
STAFF_EMAIL=
STAFF_PASSWORD=

# Strongly recommended for System Administrator wiring tests
SYSTEM_ADMIN_EMAIL=
SYSTEM_ADMIN_PASSWORD=

# Optional manager account
MANAGER_EMAIL=
MANAGER_PASSWORD=

# Safe by default. Set to 1 only in a throwaway test workspace if you want mutation buttons clicked.
CHAOS_ALLOW_MUTATION=0

# Tuning
CHAOS_TEST_WORKERS=1
CHAOS_TEST_RETRIES=0
CHAOS_MAX_SAFE_CLICKS_PER_ROUTE=45
