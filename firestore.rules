rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // 86 CHAOS PRODUCTION SECURITY RULES
    // Tenant isolation + super-admin custom claim + safer writes
    // ============================================================

    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    // Bootstrap keeps Geoff able to recover access even before custom claims are set.
    // Long-term super-admin access should come from request.auth.token.superAdmin.
    function isSuperAdmin() {
      return signedIn() && (
        request.auth.token.superAdmin == true ||
        request.auth.token.email == 'geoffm1985@gmail.com' ||
        request.auth.token.email == 'geoffrm1985@gmail.com' ||
        (hasUserDoc() && userData().isSuperAdmin == true)
      );
    }

    function isTenantMatch(restId) {
      return hasUserDoc() && userData().restaurantId == restId;
    }

    function restaurantPath(restId) {
      return /databases/$(database)/documents/restaurants/$(restId);
    }

    function hasRestaurantDoc(restId) {
      return restId is string && exists(restaurantPath(restId));
    }

    function restaurantData(restId) {
      return get(restaurantPath(restId)).data;
    }

    function isRestaurantOwner(restId) {
      return signedIn() && (
        (
          hasRestaurantDoc(restId) && (
            restaurantData(restId).ownerEmail == request.auth.token.email ||
            restaurantData(restId).ownerEmailLower == request.auth.token.email ||
            restaurantData(restId).ownerUserEmail == request.auth.token.email ||
            restaurantData(restId).ownerUserId == request.auth.uid ||
            restaurantData(restId).ownerUid == request.auth.uid
          )
        ) ||
        (
          hasUserDoc() &&
          userData().restaurantId == restId &&
          (userData().isOwner == true || userData().accountOwner == true || userData().owner == true || userData().workspaceOwner == true || userData().accountRole == 'owner')
        )
      );
    }

    function isAdmin() {
      return hasUserDoc() && userData().isAdmin == true;
    }

    function hasPerm(perm) {
      return hasUserDoc() && userData().permissions[perm] == true;
    }

    function isTenantAdmin(restId) {
      return isTenantMatch(restId) && isAdmin();
    }

    function canManageStaff(restId) {
      return isSuperAdmin() ||
        isRestaurantOwner(restId) ||
        (isTenantMatch(restId) && (isAdmin() || hasPerm('team')));
    }

    function canEditWages(restId) {
      return isSuperAdmin() ||
        isRestaurantOwner(restId) ||
        (isTenantMatch(restId) && hasPerm('wageEdit'));
    }

    function canChooseWageAccess(restId) {
      return isSuperAdmin() || isRestaurantOwner(restId);
    }

    function canManageWorkspaceSettings(restId) {
      return isSuperAdmin() ||
        isRestaurantOwner(restId) ||
        (isTenantMatch(restId) && (hasPerm('settings') || hasPerm('branding') || hasPerm('integrations')));
    }

    function restaurantSettingsWriteIsSafe(restId) {
      return canManageWorkspaceSettings(restId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'systemSettings', 'settingsHistory', 'integrations', 'updatedAt'
        ]);
    }

    function isOwnerOfRestaurantDoc() {
      return signedIn() && request.auth.token.email == resource.data.ownerEmail;
    }

    function protectedUserKeys() {
      return [
        'restaurantId',
        'isSuperAdmin',
        'isOwner',
        'accountOwner',
        'owner',
        'workspaceOwner',
        'accountRole',
        'superAdminClaimUpdatedAt',
        'superAdminClaimUpdatedBy',
        'systemAccess',
        'billingStatus',
        'planType'
      ];
    }

    function userSafeSelfUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'name', 'phone', 'photoURL', 'lastActive', 'lastSeen', 'lastHeartbeatAt', 'presenceUpdatedAt',
        'onlineState', 'activeTab', 'activeSessionId', 'activeDevice', 'activeHost', 'heartbeatEpochMs',
        'notificationPermission', 'gpsPermission', 'deviceDiagnostics',
        'fcmToken', 'fcmTokenUpdatedAt', 'lastPushTokenSyncAt', 'pushTokenHost', 'pushTokenPermission',
        'device', 'host', 'theme', 'settings', 'preferences', 'notificationPrefs',
        'forcePasswordChange', 'passwordPurgedAt', 'passwordStored'
      ]) &&
      !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedUserKeys());
    }

    function presenceSessionKeys() {
      return [
        'userId', 'uid', 'restaurantId', 'userName', 'userEmail', 'email', 'role', 'photoURL',
        'lastActive', 'lastSeen', 'lastHeartbeatAt', 'presenceUpdatedAt', 'heartbeatEpochMs',
        'onlineState', 'activeTab', 'activeSessionId', 'activeDevice', 'activeHost',
        'notificationPermission', 'gpsPermission', 'deviceDiagnostics',
        'createdAt', 'updatedAt', 'source', 'sessionId'
      ];
    }

    function presenceCreateIsSafe() {
      return request.resource.data.keys().hasOnly(presenceSessionKeys()) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.restaurantId is string &&
        isTenantMatch(request.resource.data.restaurantId);
    }

    function presenceUpdateIsSafe() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(presenceSessionKeys()) &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.restaurantId == resource.data.restaurantId &&
        resource.data.restaurantId is string &&
        isTenantMatch(resource.data.restaurantId);
    }

    function livePresenceKeys() {
      return [
        'userId', 'uid', 'restaurantId', 'userName', 'userEmail', 'email', 'role', 'photoURL',
        'lastActive', 'lastSeen', 'lastHeartbeatAt', 'presenceUpdatedAt', 'heartbeatEpochMs',
        'onlineState', 'activeTab', 'activeSessionId', 'activeDevice', 'activeHost',
        'notificationPermission', 'gpsPermission', 'deviceDiagnostics',
        'createdAt', 'updatedAt', 'source'
      ];
    }

    function livePresenceWriteIsSafe(userId) {
      return request.auth.uid == userId &&
        request.resource.data.keys().hasOnly(livePresenceKeys()) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.restaurantId is string &&
        isTenantMatch(request.resource.data.restaurantId);
    }

    function wageValueChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['wage']);
    }

    function adminFlagChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
    }

    function wagePermissionChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['permissions']) && (
        request.resource.data.permissions.wageView != resource.data.permissions.wageView ||
        request.resource.data.permissions.wageEdit != resource.data.permissions.wageEdit
      );
    }

    function settingsPermissionChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny(['permissions']) && (
        request.resource.data.permissions.settings != resource.data.permissions.settings ||
        request.resource.data.permissions.branding != resource.data.permissions.branding ||
        request.resource.data.permissions.integrations != resource.data.permissions.integrations
      );
    }

    function newUserHasSensitiveStaffFields(restId) {
      return (request.resource.data.wage is number && request.resource.data.wage > 0) ||
        request.resource.data.isAdmin == true ||
        request.resource.data.permissions.wageView == true ||
        request.resource.data.permissions.wageEdit == true ||
        request.resource.data.permissions.settings == true ||
        request.resource.data.permissions.branding == true ||
        request.resource.data.permissions.integrations == true;
    }

    function tenantStaffUserCreateIsSafe(restId) {
      return request.resource.data.restaurantId == restId &&
        request.resource.data.isSuperAdmin != true &&
        canManageStaff(restId) &&
        (
          !newUserHasSensitiveStaffFields(restId) ||
          canChooseWageAccess(restId)
        );
    }

    function tenantAdminUserUpdateIsSafe() {
      return request.resource.data.restaurantId == resource.data.restaurantId &&
        request.resource.data.isSuperAdmin == resource.data.isSuperAdmin &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'isSuperAdmin', 'superAdminClaimUpdatedAt', 'superAdminClaimUpdatedBy', 'systemAccess'
        ]) &&
        (
          !wageValueChanged() || canEditWages(resource.data.restaurantId)
        ) &&
        (
          !wagePermissionChanged() || canChooseWageAccess(resource.data.restaurantId)
        ) &&
        (
          !settingsPermissionChanged() || canChooseWageAccess(resource.data.restaurantId)
        ) &&
        (
          !adminFlagChanged() || canChooseWageAccess(resource.data.restaurantId)
        );
    }

    function commonTenantWriteAllowed(collectionName) {
      return collectionName in [
        'events', 'messages', 'shiftSwaps', 'tasks', 'timePunches',
        'tempLogs', 'wasteLogs', 'maintenanceLogs', 'offlineWriteReceipts'
      ];
    }

    function kitchenWriteAllowed(collectionName) {
      return collectionName in [
        'prepItems', 'prepCategories', 'lineCheckItems', 'recipes', 'menuDependencies'
      ] && (isAdmin() || hasPerm('prep') || hasPerm('team') || (collectionName == 'menuDependencies' && hasPerm('inventory')));
    }

    function inventoryWriteAllowed(collectionName) {
      return collectionName in [
        'inventoryItems', 'vendors', 'orders', 'invoices'
      ] && (isAdmin() || hasPerm('inventory') || hasPerm('team'));
    }

    function scheduleWriteAllowed(collectionName) {
      return collectionName in [
        'shifts', 'timeOffRequests', 'scheduleTemplates', 'scheduleCoverageTargets'
      ] && (isAdmin() || hasPerm('schedule') || hasPerm('team'));
    }

    function managerWriteAllowed(collectionName) {
      return collectionName in [
        'roles', 'pmSchedules', 'sales'
      ] && (isAdmin() || hasPerm('team') || hasPerm('sales'));
    }

    function canTenantWriteCollection(collectionName) {
      return commonTenantWriteAllowed(collectionName) ||
        kitchenWriteAllowed(collectionName) ||
        inventoryWriteAllowed(collectionName) ||
        scheduleWriteAllowed(collectionName) ||
        managerWriteAllowed(collectionName);
    }

    // ============================================================
    // USERS
    // ============================================================
    match /users/{userId} {
      allow read: if signedIn() && (
        isSuperAdmin() ||
        request.auth.uid == userId ||
        isTenantMatch(resource.data.restaurantId) ||
        isRestaurantOwner(resource.data.restaurantId)
      );

      allow create: if signedIn() && (
        isSuperAdmin() ||
        tenantStaffUserCreateIsSafe(request.resource.data.restaurantId)
      );

      allow update: if signedIn() && (
        isSuperAdmin() ||
        (
          request.auth.uid == userId &&
          userSafeSelfUpdate()
        ) ||
        (
          canManageStaff(resource.data.restaurantId) &&
          tenantAdminUserUpdateIsSafe()
        )
      );

      allow delete: if signedIn() && (
        isSuperAdmin() ||
        canManageStaff(resource.data.restaurantId)
      );
    }

    // ============================================================
    // PRESENCE SESSIONS
    // Redundant live heartbeat channel. Users may write only their
    // own session heartbeat; tenant peers/admins may read live state.
    // ============================================================
    match /presenceSessions/{sessionId} {
      allow read: if signedIn() && (
        isSuperAdmin() ||
        (resource.data.restaurantId is string && isTenantMatch(resource.data.restaurantId))
      );

      allow create: if signedIn() && presenceCreateIsSafe();
      allow update: if signedIn() && presenceUpdateIsSafe();

      allow delete: if signedIn() && (
        isSuperAdmin() ||
        resource.data.userId == request.auth.uid
      );
    }

    // Stable live presence channel: one document per user. This prevents
    // old session documents from pushing current online users out of capped reads.
    match /livePresence/{userId} {
      allow read: if signedIn() && (
        isSuperAdmin() ||
        (resource.data.restaurantId is string && isTenantMatch(resource.data.restaurantId))
      );

      allow create, update: if signedIn() && livePresenceWriteIsSafe(userId);

      allow delete: if signedIn() && (
        isSuperAdmin() ||
        userId == request.auth.uid
      );
    }

    // ============================================================
    // RESTAURANT WORKSPACES
    // ============================================================
    match /restaurants/{restaurantId} {
      allow read: if signedIn() && (
        isSuperAdmin() ||
        isTenantMatch(restaurantId) ||
        isOwnerOfRestaurantDoc()
      );

      allow create, delete: if isSuperAdmin();

      allow update: if signedIn() && (
        isSuperAdmin() ||
        isOwnerOfRestaurantDoc() ||
        restaurantSettingsWriteIsSafe(restaurantId)
      );
    }

    // ============================================================
    // AUDIT / CRASH / SYSTEM
    // ============================================================
    match /auditLogs/{docId} {
      allow read: if signedIn() && (
        isSuperAdmin() ||
        canManageStaff(resource.data.restaurantId)
      );

      allow create: if signedIn() && (
        isSuperAdmin() ||
        isTenantMatch(request.resource.data.restaurantId)
      );

      // Audit logs should be append-only from the client.
      allow update, delete: if false;
    }

    match /crashReports/{docId} {
      allow create: if signedIn();
      allow read, update, delete: if isSuperAdmin();
    }

    match /system/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================================
    // STANDARD TENANT COLLECTIONS
    // ============================================================
    match /{collectionName}/{docId} {
      allow read: if signedIn() && (
        isSuperAdmin() ||
        (
          resource.data.restaurantId is string &&
          isTenantMatch(resource.data.restaurantId)
        )
      );

      allow create: if signedIn() && (
        isSuperAdmin() ||
        (
          request.resource.data.restaurantId is string &&
          isTenantMatch(request.resource.data.restaurantId) &&
          canTenantWriteCollection(collectionName)
        )
      );

      allow update, delete: if signedIn() && (
        isSuperAdmin() ||
        (
          resource.data.restaurantId is string &&
          isTenantMatch(resource.data.restaurantId) &&
          canTenantWriteCollection(collectionName)
        )
      );
    }
  }
}
