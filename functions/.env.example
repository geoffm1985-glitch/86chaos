# 86 Chaos production retention functions
# These values belong in functions/.env.<firebase-alias> or your Firebase Functions environment.

# Required for time-clock/geofence archival. Use the bucket NAME only, not a gs:// URL.
# Example: chaos-production-retention-archive
RETENTION_ARCHIVE_BUCKET=

# Optional. Leave blank to use the Firebase project's default Storage bucket for raw AI upload cleanup.
AI_UPLOADS_BUCKET=

# Legal retention schedule implemented in functions/src/retention.ts:
# - Transient prep-list and 86-alert data: 30 days
# - Raw AI prompts, request logs, and uploaded scan files: 30 days
# - Deleted workspace data: 30-day recovery window before hard delete
# - Database backups: 30-day rolling retention
# - Audit/security logs: 1 year
# - Workforce/time-clock/geofence records: archive active records after 1 year and delete archive after 3 years
# - Active core records such as recipes and inventory: retained while the workspace/account is active
